# Copy to .env.local and fill in. Never commit .env.local.
# Get Clerk keys from https://dashboard.clerk.com after creating the app.

# Keep VITE_OWNER_EMAILS (client UI hint) and OWNER_EMAILS (server gate) in
# sync. The server is the source of truth; if they drift, owner UI is enabled
# but server calls 401.

# Client-side (Vite-exposed)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxx
VITE_OWNER_EMAILS=you@example.com,teammate@example.com

# Server-side (Vercel Functions)
CLERK_SECRET_KEY=sk_test_xxxxxxxx
OWNER_EMAILS=you@example.com,teammate@example.com

# Gemini (already in your prod/preview env)
GEMINI_API_KEY=

# Turso (already in your prod/preview env)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
