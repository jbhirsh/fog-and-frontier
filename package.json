{
  "name": "fog-and-frontier",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run lint && tsc -b && vite build",
    "typecheck": "tsc -b",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:fix": "eslint . --fix && stylelint \"src/**/*.css\" --fix",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:seed-preview": "node scripts/seed-preview-db.mjs",
    "db:snapshot": "node scripts/snapshot-prod-db.mjs",
    "db:migrate-static": "node --experimental-strip-types scripts/migrate-static-to-turso.mjs",
    "db:backfill-park-types": "node --experimental-strip-types scripts/backfill-park-types.mjs",
    "db:backfill-restaurant-info": "node --experimental-strip-types scripts/backfill-restaurant-info.mjs",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@apollo/client": "^4.2.3",
    "@apollo/server": "^5.5.1",
    "@as-integrations/express5": "^1.1.2",
    "@clerk/backend": "^3.4.7",
    "@clerk/clerk-react": "^5.61.6",
    "@libsql/client": "^0.15.0",
    "@sentry/react": "^10.53.1",
    "@types/leaflet": "^1.9.21",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "graphql": "^16.14.2",
    "graphql-scalars": "^1.25.0",
    "leaflet": "^1.9.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.15.0",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/client-preset": "^6.0.1",
    "@playwright/test": "^1.59.1",
    "@sentry/vite-plugin": "^5.3.0",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.7.15",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "stylelint": "^17.11.0",
    "stylelint-config-recommended": "^18.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
