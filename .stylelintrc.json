{
  "extends": ["stylelint-config-recommended"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "theme",
          "utility",
          "layer",
          "apply",
          "source",
          "variant",
          "custom-variant",
          "config",
          "plugin"
        ]
      }
    ],
    "no-descending-specificity": null
  }
}
