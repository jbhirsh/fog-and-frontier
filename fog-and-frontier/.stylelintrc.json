{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "theme",
          "layer",
          "utility",
          "variant",
          "apply",
          "config",
          "custom-variant",
          "plugin",
          "source",
          "reference",
          "tailwind"
        ]
      }
    ],
    "custom-property-pattern": null,
    "selector-class-pattern": null,
    "no-descending-specificity": null
  },
  "ignoreFiles": ["dist/**", "coverage/**", "node_modules/**"]
}
