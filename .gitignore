# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Dependencies
node_modules/

# Lockfiles (override the global ignore — npm ci needs these committed)
!package-lock.json

# Build output
dist/
dist-ssr/
*.local

# Test artifacts
coverage/

# Vercel
.vercel/
.env
.env.local
.env.*.local
.env.prod
.env.preview

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.swp
.vercel

# Local DB snapshot (run `npm run db:snapshot` to regenerate)
dev-db.sqlite
dev-db.sqlite-*

# Local Turso backups (incident #24). Never commit — may contain prod data.
backups/

# Playwright transient output. Baselines under tests/visual/**/*-snapshots ARE committed.
test-results/
playwright-report/
blob-report/
.playwright/

# Claude Code per-session state (worktrees, scratch)
.claude/

# Caliber runtime state, logs, and caches. The curated CALIBER_LEARNINGS.md IS committed; this dir is not.
.caliber/

# Leftover from pre-flatten directory layout
fog-and-frontier/

# Vite scratch
.vite/

# Planning scratch (not committed)
PLAN_*.md
